{
  "name": "nestnext-cleanarch-backend",
  "version": "0.1.0",
  "description": "NestNext-cleanArch boilerplate API (NestJS + MongoDB)",
  "private": true,
  "license": "MIT",
  "scripts": {
    "seed:create:document": "hygen seeds create-document",
    "generate:resource:document": "hygen generate document-resource",
    "postgenerate:resource:document": "npm run lint -- --fix",
    "add:property:to-document": "hygen property add-to-document",
    "postadd:property:to-document": "npm run lint -- --fix",
    "seed:run:document": "ts-node -r tsconfig-paths/register ./src/database/seeds/document/run-seed.ts",
    "prebuild": "rimraf dist tsconfig.build.tsbuildinfo",
    "build": "nest build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.2.6",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.3.1",
    "mongoose": "9.4.1",
    "mongoose-autopopulate": "^1.2.1",
    "ms": "2.1.3",
    "passport": "0.7.0",
    "passport-anonymous": "1.0.1",
    "passport-jwt": "4.0.1",
    "redis": "^5.12.1",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "source-map-support": "0.5.21",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "11.0.18",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@types/bcryptjs": "3.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/ms": "2.1.0",
    "@types/node": "25.5.0",
    "@types/passport-anonymous": "1.0.5",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "^17.4.0",
    "hygen": "6.2.11",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
